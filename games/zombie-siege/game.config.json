{
  "id": "zombie-siege",
  "name": "Siège Zombie",
  "description": "Coop — éliminez les zombies qui escaladent l'immeuble avant qu'ils n'atteignent le toit !",
  "version": "1.0.0",
  "columns": 7,
  "players": { "min": 1, "max": 99 },
  "icon": "🧟",
  "accent": "#8b0000",
  "server": { "entry": "server/index.js" },
  "controller": {
    "actions": [
      {
        "id": "reset",
        "label": "Nouvelle partie",
        "method": "POST",
        "path": "/api/reset",
        "style": "primary"
      },
      {
        "id": "reset-scores",
        "label": "Réinitialiser TOP score",
        "method": "POST",
        "path": "/api/reset-scores",
        "style": "danger",
        "confirm": "Remettre le TOP score à zéro ?"
      }
    ]
  },
  "docs": "docs/README.md"
}
